<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Avancerade ansiktsbehandlingar hos Your Skin Clinic i Stockholm. Signature Glow, Collagen Boost, Nano Infusion, Acne Detox och mer. Boka tid idag.">
  <title>Avancerade ansiktsbehandlingar – Your Skin Clinic Stockholm</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="style.css">
  <link rel="stylesheet" href="treatment.css">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><text y='28' font-size='28'>✦</text></svg>">

  <style>
    /* --- Treatment Guide Grid --- */
    .tx-guide {
      padding: clamp(2.5rem, 5vw, 4rem) 0;
      background: var(--white);
    }
    .tx-guide-header {
      text-align: center;
      margin-bottom: 2rem;
    }
    .tx-guide-header h2 {
      font-family: var(--font-heading);
      font-size: clamp(1.3rem, 2.5vw, 1.7rem);
      font-weight: 600;
      color: var(--accent);
      margin-bottom: .5rem;
      text-transform: uppercase;
      letter-spacing: .04em;
    }
    .tx-guide-header p {
      font-size: .9rem;
      color: var(--text-muted);
    }
    .tx-guide-grid {
      display: grid;
      gap: 1rem;
      max-width: 880px;
      margin: 0 auto;
    }
    @media (min-width: 600px) {
      .tx-guide-grid { grid-template-columns: repeat(4, 1fr); }
    }
    @media (min-width: 400px) and (max-width: 599px) {
      .tx-guide-grid { grid-template-columns: repeat(2, 1fr); }
    }
    .tx-guide-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: var(--radius-md);
      padding: 1.5rem 1.25rem;
      text-align: center;
      transition: box-shadow var(--transition), border-color var(--transition);
    }
    .tx-guide-card:hover {
      border-color: var(--gold);
      box-shadow: 0 4px 20px rgba(0,0,0,.06);
    }
    .tx-guide-icon {
      font-size: 1.5rem;
      margin-bottom: .5rem;
      color: var(--gold);
    }
    .tx-guide-label {
      font-family: var(--font-heading);
      font-weight: 600;
      font-size: .95rem;
      color: var(--accent);
      margin-bottom: .4rem;
    }
    .tx-guide-desc {
      font-size: .78rem;
      color: var(--text-muted);
      line-height: 1.5;
      margin-bottom: .6rem;
    }
    .tx-guide-rec {
      font-size: .75rem;
      color: var(--gold);
      font-weight: 500;
      letter-spacing: .03em;
    }
    .tx-guide-rec a {
      color: var(--gold);
      text-decoration: none;
      border-bottom: 1px solid transparent;
      transition: border-color var(--transition);
    }
    .tx-guide-rec a:hover { border-color: var(--gold); }

    /* --- Treatment List (Row-based) --- */
    .tl-section {
      padding: clamp(3rem, 5vw, 4.5rem) 0;
      background: var(--bg-primary);
    }
    .tl-list {
      max-width: 960px;
      margin: 0 auto;
    }

    /* Row */
    .tl-row {
      border-bottom: 1px solid var(--border);
    }
    .tl-row:first-child {
      border-top: 1px solid var(--border);
    }

    /* Row header (collapsed bar) */
    .tl-row-header {
      display: grid;
      grid-template-columns: 2.2rem 1fr auto;
      align-items: center;
      gap: .5rem;
      padding: 1.1rem 0;
      cursor: pointer;
      user-select: none;
      transition: background var(--transition);
    }
    .tl-row-header:hover {
      background: rgba(198,162,126,.04);
    }

    .tl-num {
      font-family: var(--font-heading);
      font-weight: 600;
      font-size: .85rem;
      color: var(--text-muted);
      text-align: center;
    }

    .tl-main {
      display: flex;
      flex-wrap: wrap;
      align-items: baseline;
      gap: .25rem .75rem;
      min-width: 0;
    }
    .tl-name {
      font-family: var(--font-heading);
      font-weight: 600;
      font-size: 1rem;
      color: var(--accent);
      white-space: nowrap;
    }
    .tl-duration {
      font-size: .8rem;
      color: var(--text-muted);
      white-space: nowrap;
    }
    .tl-desc {
      width: 100%;
      font-size: .82rem;
      color: var(--text-muted);
      line-height: 1.5;
      margin-top: .15rem;
    }

    .tl-actions {
      display: flex;
      align-items: center;
      gap: .75rem;
      flex-shrink: 0;
      padding-left: .5rem;
    }
    .tl-price {
      font-family: var(--font-heading);
      font-weight: 600;
      font-size: .95rem;
      color: var(--accent);
      white-space: nowrap;
    }
    .tl-boka {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: .5rem 1.25rem;
      font-size: .78rem;
      font-weight: 600;
      letter-spacing: .06em;
      text-transform: uppercase;
      background: var(--accent);
      color: var(--white);
      border: none;
      border-radius: 4px;
      text-decoration: none;
      transition: background var(--transition);
      white-space: nowrap;
    }
    .tl-boka:hover { background: #3d3733; }

    .tl-toggle {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: .15rem;
      background: none;
      border: none;
      cursor: pointer;
      padding: .25rem;
      color: var(--text-muted);
      transition: color var(--transition);
    }
    .tl-toggle:hover { color: var(--accent); }
    .tl-toggle svg {
      transition: transform .3s ease;
    }
    .tl-toggle-text {
      font-size: .65rem;
      letter-spacing: .03em;
      color: var(--text-muted);
    }
    .tl-row.is-open .tl-toggle svg {
      transform: rotate(180deg);
    }

    /* Expanded panel */
    .tl-panel {
      max-height: 0;
      overflow: hidden;
      transition: max-height .4s ease, padding .3s ease;
      background: var(--bg-secondary);
      border-radius: 0 0 var(--radius-md) var(--radius-md);
    }
    .tl-row.is-open .tl-panel {
      max-height: 800px;
      padding: 1.5rem 0;
    }
    .tl-panel-inner {
      display: grid;
      gap: 1.5rem;
      padding: 0 1.5rem;
    }
    @media (min-width: 700px) {
      .tl-panel-inner {
        grid-template-columns: repeat(4, 1fr);
        gap: 2rem;
      }
    }
    .tl-detail h4 {
      font-family: var(--font-heading);
      font-size: .78rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: .06em;
      color: var(--accent);
      margin-bottom: .6rem;
    }
    .tl-detail ul {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .tl-detail ul li {
      font-size: .82rem;
      color: var(--text-body);
      line-height: 1.6;
      padding-left: 1rem;
      position: relative;
    }
    .tl-detail ul li::before {
      content: "•";
      position: absolute;
      left: 0;
      color: var(--gold);
    }
    .tl-detail p {
      font-size: .82rem;
      color: var(--text-body);
      line-height: 1.6;
    }

    /* Trust bar */
    .tl-trust {
      padding: 2.5rem 0;
      background: var(--bg-secondary);
      border-top: 1px solid var(--border);
    }
    .tl-trust-grid {
      display: grid;
      gap: 1.5rem;
      text-align: center;
    }
    @media (min-width: 600px) {
      .tl-trust-grid { grid-template-columns: repeat(4, 1fr); }
    }
    .tl-trust-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: .4rem;
    }
    .tl-trust-icon {
      font-size: 1.3rem;
      color: var(--gold);
    }
    .tl-trust-label {
      font-family: var(--font-heading);
      font-weight: 600;
      font-size: .85rem;
      color: var(--accent);
    }
    .tl-trust-desc {
      font-size: .75rem;
      color: var(--text-muted);
      line-height: 1.4;
    }

    /* Consultation CTA */
    .tl-consult-cta {
      padding: clamp(2.5rem, 5vw, 3.5rem) 0;
      background: var(--accent);
      text-align: center;
    }
    .tl-consult-cta h2 {
      font-family: var(--font-heading);
      font-size: clamp(1.2rem, 2.5vw, 1.6rem);
      font-weight: 600;
      color: var(--white);
      margin-bottom: .5rem;
    }
    .tl-consult-cta p {
      font-size: .9rem;
      color: rgba(255,255,255,.8);
      margin-bottom: 1.5rem;
    }
    .tl-consult-btn {
      display: inline-flex;
      align-items: center;
      gap: .5rem;
      padding: .75rem 2rem;
      font-size: .85rem;
      font-weight: 600;
      letter-spacing: .05em;
      text-transform: uppercase;
      background: var(--white);
      color: var(--accent);
      border: none;
      border-radius: 4px;
      text-decoration: none;
      transition: background var(--transition), transform var(--transition);
    }
    .tl-consult-btn:hover { background: var(--bg-secondary); transform: translateY(-1px); }

    /* Mobile adjustments */
    @media (max-width: 699px) {
      .tl-row-header {
        grid-template-columns: 1.5rem 1fr;
        gap: .4rem;
      }
      .tl-actions {
        grid-column: 1 / -1;
        justify-content: space-between;
        padding-left: 1.9rem;
        padding-top: .4rem;
      }
      .tl-desc {
        font-size: .78rem;
      }
    }
  </style>
</head>
<body>

  <!-- ========== HEADER ========== -->
  <header class="header" id="header">
