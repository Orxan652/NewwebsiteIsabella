  </div>

  <!-- ========== HERO ========== -->
  <section class="tx-hero">
    <div class="tx-hero-bg">
      <div style="background: linear-gradient(135deg, var(--accent) 0%, #4a4340 100%); width:100%; height:100%;"></div>
    </div>
    <div class="tx-hero-overlay"></div>
    <div class="container">
      <div class="tx-hero-content fade-in">
        <a href="index.html#behandlingar" class="tx-breadcrumb">← Alla behandlingar</a>
        <h1>Avancerade ansiktsbehandlingar</h1>
        <p>Skräddarsydda behandlingar för din hud – med fokus på resultat, balans och långsiktig hudhälsa.</p>
        <div class="tx-hero-btns">
          <a href="https://www.bokadirekt.se/places/your-skin-clinic-48263" target="_blank" rel="noopener" class="btn btn-white">Boka tid</a>
          <a href="https://www.bokadirekt.se/boka-tjanst/your-skin-clinic-48263/konsultation-hud-laser-harborttagning-2170427" target="_blank" rel="noopener" class="btn btn-outline-white">Boka konsultation</a>
        </div>
      </div>
    </div>
  </section>


  <!-- ========== SECTION: VÄLJ RÄTT BEHANDLING ========== -->
  <section class="tx-guide">
    <div class="container">
      <h2 class="fade-in">Vilken behandling passar dig?</h2>
      <div class="tx-guide-grid fade-in">
        <div class="tx-guide-card">
          <div class="tx-guide-label">Glow &amp; lyster</div>
          <div class="tx-guide-rec">Signature Glow / Glass Skin</div>
        </div>
        <div class="tx-guide-card">
          <div class="tx-guide-label">Anti-age &amp; kvalitet</div>
          <div class="tx-guide-rec">Collagen Boost / Nano Infusion</div>
        </div>
        <div class="tx-guide-card">
          <div class="tx-guide-label">Akne &amp; orenheter</div>
          <div class="tx-guide-rec">Acne Detox</div>
        </div>
        <div class="tx-guide-card">
          <div class="tx-guide-label">Känslig hud</div>
          <div class="tx-guide-rec">Barrier Repair / Rosacea</div>
        </div>
      </div>
    </div>
  </section>


  <!-- ========== SECTION: GLOW & LYSTER ========== -->
  <section class="tx-cards-section">
    <div class="container">
      <h2 class="tx-category-title fade-in">Glow &amp; lyster</h2>

      <div class="tx-cards-grid">

        <!-- Signature Glow Facial -->
        <article class="tx-card tx-card--featured fade-in">
          <div class="tx-card-badge">Populärast</div>
          <div class="tx-card-header">
            <h3>Signature Glow Facial</h3>
            <span class="tx-card-sub">Exfoliering, ljusterapi &amp; glow</span>
          </div>
          <p class="tx-card-desc">Maximal lyster och jämn hudstruktur – utan downtime.</p>

          <a href="https://www.bokadirekt.se/places/your-skin-clinic-48263" target="_blank" rel="noopener" class="btn btn-primary btn-sm tx-card-btn">Boka</a>

          <div class="tx-accordion">
            <button class="tx-accordion-trigger" aria-expanded="false">
              <span>Passar dig som</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="tx-accordion-panel">
              <ul>
                <li>Har trött, glåmig eller torr hud</li>
                <li>Vill ha glow inför event</li>
                <li>Har ojämn hudton eller struktur</li>
              </ul>
            </div>

            <button class="tx-accordion-trigger" aria-expanded="false">
              <span>Så fungerar behandlingen</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="tx-accordion-panel">
              <p>Kombinerar mekanisk exfoliering (dermaplaning) och kemisk peeling för att avlägsna döda hudceller och stimulera cellförnyelse. Samtidigt tillförs aktiva ingredienser och cirkulationen ökar genom massage och ljusterapi.</p>
            </div>

            <button class="tx-accordion-trigger" aria-expanded="false">
              <span>Resultat</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="tx-accordion-panel">
              <ul>
                <li>Direkt glow</li>
                <li>Slätare hud</li>
                <li>Jämnare hudstruktur</li>
              </ul>
            </div>

            <button class="tx-accordion-trigger" aria-expanded="false">
              <span>Ej lämplig vid</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="tx-accordion-panel">
              <ul>
                <li>Aktiv akne</li>
                <li>Irritation</li>
                <li>Retinoidkur</li>
              </ul>
            </div>
          </div>
        </article>

        <!-- Glass Skin Hydration -->
        <article class="tx-card fade-in">
          <div class="tx-card-header">
            <h3>Glass Skin Hydration</h3>
            <span class="tx-card-sub">Intensiv fukt &amp; lyster</span>
          </div>
          <p class="tx-card-desc">Intensiv fuktboost för plumpad hud och maximal lyster.</p>

          <a href="https://www.bokadirekt.se/places/your-skin-clinic-48263" target="_blank" rel="noopener" class="btn btn-primary btn-sm tx-card-btn">Boka</a>

          <div class="tx-accordion">
            <button class="tx-accordion-trigger" aria-expanded="false">
              <span>Passar dig som</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="tx-accordion-panel">
              <ul>
                <li>Har torr eller uttorkad hud</li>
                <li>Vill ha plumpad, daggfrisk look</li>
                <li>Söker intensiv återfuktning</li>
              </ul>
            </div>

            <button class="tx-accordion-trigger" aria-expanded="false">
              <span>Så fungerar behandlingen</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="tx-accordion-panel">
              <p>Arbetar i flera lager med återfuktande ingredienser som binder fukt i huden och stärker hudbarriären.</p>
            </div>

            <button class="tx-accordion-trigger" aria-expanded="false">
              <span>Resultat</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="tx-accordion-panel">
              <ul>
                <li>Mjukare hud</li>
                <li>Ökad spänst</li>
                <li>Jämn glow</li>
              </ul>
            </div>

            <button class="tx-accordion-trigger" aria-expanded="false">
              <span>Ej lämplig vid</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="tx-accordion-panel">
              <ul>
                <li>Aktiv hudinfektion</li>
                <li>Öppen eller irriterad hud</li>
              </ul>
            </div>
          </div>
        </article>

        <!-- Chemical Glow Peel -->
        <article class="tx-card fade-in">
          <div class="tx-card-header">
            <h3>Chemical Glow Peel</h3>
            <span class="tx-card-sub">Peeling &amp; hudförnyelse</span>
          </div>
          <p class="tx-card-desc">Resultatinriktad peeling för lyster och hudförnyelse.</p>

          <a href="https://www.bokadirekt.se/places/your-skin-clinic-48263" target="_blank" rel="noopener" class="btn btn-primary btn-sm tx-card-btn">Boka</a>

          <div class="tx-accordion">
            <button class="tx-accordion-trigger" aria-expanded="false">
              <span>Passar dig som</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="tx-accordion-panel">
              <ul>
                <li>Vill ha klarare, mer strålande hud</li>
                <li>Har ojämn hudton eller matt hy</li>
                <li>Söker resultatinriktad peeling</li>
              </ul>
            </div>

            <button class="tx-accordion-trigger" aria-expanded="false">
              <span>Så fungerar behandlingen</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="tx-accordion-panel">
              <p>Kemiska syror exfolierar huden, stimulerar cellförnyelse och förbättrar hudens struktur och klarhet.</p>
            </div>

            <button class="tx-accordion-trigger" aria-expanded="false">
              <span>Resultat</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="tx-accordion-panel">
              <ul>
                <li>Klarare hud</li>
                <li>Jämnare ton</li>
                <li>Förbättrad struktur</li>
              </ul>
            </div>

            <button class="tx-accordion-trigger" aria-expanded="false">
              <span>Ej lämplig vid</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="tx-accordion-panel">
              <ul>
                <li>Graviditet eller amning</li>
                <li>Aktiv hudinfektion eller irriterad hud</li>
                <li>Nylig solexponering</li>
              </ul>
            </div>
          </div>
        </article>

      </div>
    </div>
  </section>


  <!-- ========== SECTION: ANTI-AGE & KVALITET ========== -->
