      <a href="https://www.bokadirekt.se/places/your-skin-clinic-48263" target="_blank" rel="noopener" class="btn btn-primary btn-sm header-cta">Boka tid</a>

      <button class="hamburger" id="hamburger" aria-label="Öppna meny" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </header>

  <!-- Mobile nav -->
  <div class="mobile-nav" id="mobileNav">
    <a href="index.html#behandlingar">Behandlingar</a>
